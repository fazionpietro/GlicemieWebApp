                                 referencedTableName="pazienti"/>
    </changeSet>
    <changeSet id="1756130686799-16" author="pietro">
        <addForeignKeyConstraint baseColumnNames="id_paziente" baseTableName="segnalazioni"
                                 constraintName="FK_SEGNALAZIONI_ON_ID_PAZIENTE" referencedColumnNames="id_paziente"
                                 referencedTableName="pazienti"/>
    </changeSet>
    <changeSet id="1756130686799-17" author="pietro">
        <addForeignKeyConstraint baseColumnNames="id_sintomo" baseTableName="segnalazioni"
                                 constraintName="FK_SEGNALAZIONI_ON_ID_SINTOMO" referencedColumnNames="id_sintomo"
                                 referencedTableName="sintomi"/>
    </changeSet>
    <changeSet id="1756130686799-18" author="pietro">
        <addForeignKeyConstraint baseColumnNames="id_farmaco" baseTableName="terapie"
                                 constraintName="FK_TERAPIE_ON_ID_FARMACO" referencedColumnNames="id_farmaco"
                                 referencedTableName="farmaci"/>
    </changeSet>
    <changeSet id="1756130686799-19" author="pietro">
        <addForeignKeyConstraint baseColumnNames="id_paziente" baseTableName="terapie"
                                 constraintName="FK_TERAPIE_ON_ID_PAZIENTE" referencedColumnNames="id_paziente"
                                 referencedTableName="pazienti"/>
    </changeSet>
    <changeSet id="1756130686799-20" author="pietro">
        <addForeignKeyConstraint baseColumnNames="medico_curante" baseTableName="terapie"
                                 constraintName="FK_TERAPIE_ON_MEDICO_CURANTE" referencedColumnNames="id_utente"
                                 referencedTableName="utenti"/>
    </changeSet>

</databaseChangeLog>