<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1756130686799-1" author="pietro">
        <createTable tableName="assunzioni">
            <column name="id_assunzione" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_assunzioni"/>
            </column>
            <column name="id_farmaco" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="quantita" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="timestamp" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="id_paziente" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1756130686799-2" author="pietro">
        <createTable tableName="farmaci">
            <column name="id_farmaco" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_farmaci"/>
            </column>
            <column name="nome" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="bugiardino" type="VARCHAR(2147483647)"/>
        </createTable>
    </changeSet>
    <changeSet id="1756130686799-3" author="pietro">
        <createTable tableName="logs">
            <column name="id_log" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_logs"/>
            </column>
            <column name="descrizione" type="VARCHAR(2147483647)">
                <constraints nullable="false"/>
            </column>
            <column name="timestamp" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1756130686799-4" author="pietro">
        <createTable tableName="pazienti">
            <column name="id_paziente" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_pazienti"/>
            </column>
            <column name="fattori_rischio" type="VARCHAR(2147483647)"/>
            <column name="comorbita" type="VARCHAR(2147483647)"/>
            <column name="patologie_pregresse" type="VARCHAR(2147483647)"/>
            <column name="id_medico" type="UUID"/>
        </createTable>
    </changeSet>
    <changeSet id="1756130686799-5" author="pietro">
        <createTable tableName="rilevazioni">
            <column name="id_rilevazione" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_rilevazioni"/>
            </column>
            <column name="id_paziente" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="valore" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="timestamp" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1756130686799-6" author="pietro">
        <createTable tableName="segnalazioni">
            <column name="id_segnalazione" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_segnalazioni"/>
            </column>
            <column name="id_sintomo" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="id_paziente" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="intensita" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="descrizione" type="VARCHAR(2147483647)">
                <constraints nullable="false"/>
            </column>
            <column name="timestamp" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1756130686799-7" author="pietro">
        <createTable tableName="sintomi">
            <column name="id_sintomo" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_sintomi"/>
            </column>
            <column name="nome" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="descrizione" type="VARCHAR(2147483647)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1756130686799-8" author="pietro">
        <createTable tableName="terapie">
            <column name="id_terapia" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_terapie"/>
            </column>
            <column name="id_farmaco" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="num_assunzioni" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="quantita" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="indicazioni" type="VARCHAR(2147483647)"/>
            <column name="id_paziente" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="medico_curante" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1756130686799-9" author="pietro">
        <createTable tableName="utenti">
            <column name="id_utente" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_utenti"/>
            </column>
            <column name="email" type="VARCHAR(320)">
                <constraints nullable="false"/>
            </column>
            <column name="password_hash" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="nome" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="cognome" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="data_nascita" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="ruolo" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1756130686799-10" author="pietro">
        <addUniqueConstraint columnNames="email" constraintName="uc_utenti_email" tableName="utenti"/>
    </changeSet>
    <changeSet id="1756130686799-11" author="pietro">
        <addForeignKeyConstraint baseColumnNames="id_farmaco" baseTableName="assunzioni"
                                 constraintName="FK_ASSUNZIONI_ON_ID_FARMACO" referencedColumnNames="id_farmaco"
                                 referencedTableName="farmaci"/>
    </changeSet>
    <changeSet id="1756130686799-12" author="pietro">
        <addForeignKeyConstraint baseColumnNames="id_paziente" baseTableName="assunzioni"
                                 constraintName="FK_ASSUNZIONI_ON_ID_PAZIENTE" referencedColumnNames="id_paziente"
                                 referencedTableName="pazienti"/>
    </changeSet>
    <changeSet id="1756130686799-13" author="pietro">
        <addForeignKeyConstraint baseColumnNames="id_medico" baseTableName="pazienti"
                                 constraintName="FK_PAZIENTI_ON_ID_MEDICO" referencedColumnNames="id_utente"
                                 referencedTableName="utenti"/>
    </changeSet>
    <changeSet id="1756130686799-14" author="pietro">
        <addForeignKeyConstraint baseColumnNames="id_paziente" baseTableName="pazienti"
                                 constraintName="FK_PAZIENTI_ON_ID_PAZIENTE" referencedColumnNames="id_utente"
                                 referencedTableName="utenti"/>
    </changeSet>
    <changeSet id="1756130686799-15" author="pietro">
        <addForeignKeyConstraint baseColumnNames="id_paziente" baseTableName="rilevazioni"
